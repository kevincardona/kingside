# Godot 4+ specific ignores
.godot/
/android/

# Local OS/editor state
.DS_Store
*.log
*.tmp
*.temp
*.swp

# Export/build artifacts
/build/
# Chess.pck — compiled game bundle (all scripts + assets). A build artifact,
# regenerated by tools/ios_deploy.sh or `godot --export-pack`; not tracked.
/Chess.pck

# Godot needlessly imports the Xcode-only app-icon/splash PNGs under Chess/
# (that folder carries a .gdignore). Ignore any stray .import it still emits.
/Chess/**/*.import
/Chess.xcodeproj/project.xcworkspace/xcuserdata/
/Chess.xcodeproj/xcuserdata/
/Chess.xcodeproj/xcshareddata/WorkspaceSettings.xcsettings

# Native extension build trees. Keep checked-in runtime binaries under
# gdextension/bin/, but ignore CMake/Xcode intermediate products.
/gdextension/build-*/
/gdextension/.cache/

# godot-cpp and stockfish are build dependencies (cloned/built locally).
# Their compiled output + generated bindings are huge and regenerable.
/gdextension/godot-cpp/
/gdextension/stockfish/

# Godot iOS export templates / Vulkan loader — regenerated by the iOS export,
# must never be committed (hundreds of MB of libgodot.a / MoltenVK).
# /Chess.xcframework/
# /MoltenVK.xcframework/

# Stray prebuilt Stockfish CLI binaries — unused (the app uses the in-process
# GDExtension, not these standalone executables).
/stockfish/

# Xcode build intermediates / DerivedData
/Chess.xcodeproj/project.xcworkspace/
*.xcuserstate

# Claude Code local tooling / settings — never publish
.claude/

# Xcode DerivedData (used by tools/ios_deploy.sh) + iOS export residue
/.build/
/Chess/dylibs/
/Chess.ipa
/libgodot_camera.visionos.*.xcframework/
/docs/**/*.import
